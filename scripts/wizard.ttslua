function update_topography_wizard_page()
  local defender
  if g_game_settings['invader'] == "red" then
    defender = "blue"
  else
    defender = "red"
  end
  UI.setAttribute("wizard_panel_topography_defender", "text", defender)

  local topography_name = g_game_settings[ 'topography']
  UI.setAttribute("wizard_button_go_forward_to_tactical_advantage",
    "interactable", topography_name ~= nil)
end

