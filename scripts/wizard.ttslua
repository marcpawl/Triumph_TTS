-- Update the UI element for an armies invasion rating
-- id: identifier of the UI element
-- rating: Army's invasion rating
function set_invasion_rating_selected(id, rating)
  if rating == nil then
    rating = 1
  end
  g_game_settings[id] = rating
  local options = {"1", "2", "3", "4", "5", "6"}
  set_options_dropdown_by_id(id, options, rating)
end

function on_red_invasion_rating_selected(player, value, id)
  print_info("Red invasion rating " .. tostring(value))
  local rating = tonumber(value)
  g_game_settings['red_invasion_rating'] = rating
  set_invasion_rating_selected(id, rating)
  update_invasion_wizard_page()
end

function on_blue_invasion_rating_selected(player, value, id)
  print_info("Blue invasion rating " .. tostring(value))
  local rating = tonumber(value)
  g_game_settings['blue_invasion_rating'] = rating
  set_invasion_rating_selected(id, rating)
  update_invasion_wizard_page()
end

function on_button_red_invasion_roll()
  roll_dice('red')
end

function on_button_blue_invasion_roll()
  roll_dice('blue')
end


