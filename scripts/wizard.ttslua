function do_update_terrain_pieces_wizard_page()
  local red_dice_id = "wizard_red_terrain_pieces_roll_value"
  local blue_dice_id = "wizard_blue_terrain_pieces_roll_value"
  local red_dice = get_ui_numeric_value(red_dice_id)
  local blue_dice = get_ui_numeric_value(blue_dice_id)
  if red_dice == nil or blue_dice == nil then
    UI.setAttribute("wizard_panel_terrain_pieces_roll_next", "interactable", false)
    return
  end
  g_game_settings['terrain_pieces_dice_roll'] = red_dice + blue_dice
  UI.setAttribute("wizard_panel_terrain_pieces_roll_next", "interactable", true)
end


function update_terrain_pieces_roll_page()
